---
// This page uses the main layout to get the header, footer, and global styles.
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

// 1. Fetch all blog posts from your `src/content/blog/` directory.
const allPosts = await getCollection("blog");

// 2. Sort the posts to show the newest one first. This is standard for a blog.
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<MainLayout title="Blog | File Pro">
  <!-- Centered container for the blog content -->
  <div class="max-w-3xl mx-auto">

    <!-- Page Header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl font-extrabold mb-4">File Pro Blog</h1>
      <p class="text-lg text-gray-600 dark:text-gray-300">
        Insights, updates, and articles about our tools and the industry.
      </p>
    </div>

    <!-- This div will contain the list of dynamically generated blog post cards -->
    <div class="space-y-8">
      {sortedPosts.map((post: CollectionEntry<"blog">) => (
        <article class="bg-white dark:bg-gray-800 p-6 rounded-lg shadow-md border border-gray-200 dark:border-gray-700 hover:shadow-xl transition">
          
          <!-- Post Title (from your .md file) -->
          <h2 class="text-2xl font-bold mb-2">
            <a href={`/blog/${post.slug}/`} class="text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition">
              {post.data.title}
            </a>
          </h2>

          <!-- Publication Date (from your .md file) -->
          <time datetime={post.data.date.toISOString()} class="text-sm text-gray-500">
            Published on: {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>

          <!-- Post Description (from your .md file) -->
          <p class="text-gray-700 dark:text-gray-300 my-4">
            {post.data.description}
          </p>

          <!-- Read More Link -->
          <a href={`/blog/${post.slug}/`} class="font-semibold text-blue-600 dark:text-blue-400 hover:underline">
            Read More →
          </a>

        </article>
      ))}
    </div>

  </div>
</MainLayout>