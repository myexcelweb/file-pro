---
// This page uses the main layout to get the header, footer, and global styles.
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Contact Parimal Hodar | File Pro"
  description="Get in touch with Parimal Hodar for support, collaboration, or inquiries about the File Pro suite of professional digital tools for PDF, Excel, and AI image editing."
  keywords="Parimal Hodar, Contact, digital tools, PDF editor, Excel tools, AI image editor, support, collaboration"
>
  <!-- Hero Section with Gradient Background -->
  <div class="min-h-[80vh] flex items-center justify-center relative overflow-hidden">
    <!-- Background Elements -->
    <div class="absolute inset-0 bg-gradient-to-br from-blue-50 to-indigo-100 dark:from-gray-900 dark:to-gray-800"></div>
    <div class="absolute top-10 left-10 w-72 h-72 bg-blue-200 dark:bg-blue-900 rounded-full mix-blend-multiply filter blur-xl opacity-30 animate-pulse"></div>
    <div class="absolute bottom-10 right-10 w-72 h-72 bg-purple-200 dark:bg-purple-900 rounded-full mix-blend-multiply filter blur-xl opacity-30 animate-pulse delay-1000"></div>
    
    <!-- Main Content Container -->
    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
      <!-- Main Heading -->
      <div class="mb-8">
        <h1 class="text-5xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
          Get In Touch
        </h1>
        <p class="text-xl md:text-2xl text-gray-700 dark:text-gray-300 max-w-2xl mx-auto leading-relaxed">
          Have questions, suggestions, or just want to say hello? 
          <br class="hidden md:block">
          We'd love to hear from you!
        </p>
      </div>

      <!-- Contact Card -->
      <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-2xl p-8 md:p-12 backdrop-blur-sm bg-opacity-90 dark:bg-opacity-90 border border-gray-200 dark:border-gray-700">
        <!-- Email Section -->
        <div class="mb-8">
          <div class="inline-flex items-center justify-center w-16 h-16 bg-blue-100 dark:bg-blue-900 rounded-full mb-6">
            <i class="fas fa-envelope text-2xl text-blue-600 dark:text-blue-400"></i>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">
            Email Us Directly
          </h2>
          <p class="text-gray-600 dark:text-gray-400 mb-8 max-w-md mx-auto">
            The fastest way to reach Parimal Hodar is through email. We typically respond within 24 hours.
          </p>
        </div>

        <!-- Email Display & Button -->
        <div class="space-y-6">
          <!-- Email Address Display -->
          <div class="bg-gray-50 dark:bg-gray-700 rounded-lg p-4 border-2 border-dashed border-gray-300 dark:border-gray-600">
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-2">Our Email Address:</p>
            <p class="text-lg font-mono font-semibold text-gray-900 dark:text-white break-all">
              parimalhodar.dev@gmail.com
            </p>
          </div>

          <!-- Action Buttons -->
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <!-- Primary Email Button -->
            <a
              href="mailto:parimalhodar.dev@gmail.com"
              class="group inline-flex items-center justify-center bg-gradient-to-r from-blue-600 to-blue-700 text-white px-8 py-4 rounded-xl font-semibold hover:from-blue-700 hover:to-blue-800 transition-all duration-300 transform hover:scale-105 hover:shadow-xl"
            >
              <i class="fas fa-envelope mr-3 group-hover:animate-bounce"></i>
              Send Email Now
            </a>

            <!-- Copy Email Button -->
            <button
              id="copyEmailBtn"
              class="inline-flex items-center justify-center bg-gray-200 dark:bg-gray-700 text-gray-800 dark:text-gray-200 px-8 py-4 rounded-xl font-semibold hover:bg-gray-300 dark:hover:bg-gray-600 transition-all duration-300 transform hover:scale-105"
            >
              <i class="fas fa-copy mr-3"></i>
              Copy Email
            </button>
          </div>
        </div>

        <!-- Response Time Info -->
        <div class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-700">
          <div class="flex items-center justify-center space-x-6 text-sm text-gray-500 dark:text-gray-400">
            <div class="flex items-center">
              <i class="fas fa-clock mr-2 text-green-500"></i>
              <span>Quick Response</span>
            </div>
            <div class="flex items-center">
              <i class="fas fa-shield-alt mr-2 text-blue-500"></i>
              <span>Secure & Private</span>
            </div>
            <div class="flex items-center">
              <i class="fas fa-heart mr-2 text-red-500"></i>
              <span>We Care</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Additional Info -->
      <div class="mt-12 max-w-2xl mx-auto">
        <p class="text-gray-600 dark:text-gray-400 text-lg">
          Whether you have feedback, need support, or want to collaborate, 
          Parimal Hodar is here to help and would love to connect with you.
        </p>
      </div>
    </div>
  </div>

  <!-- Copy Success Toast -->
  <div id="copyToast" class="fixed top-4 right-4 bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg transition-all duration-300 z-50 opacity-0 transform translate-y-2 pointer-events-none">
    <div class="flex items-center">
      <i class="fas fa-check-circle mr-2"></i>
      <span>Email copied to clipboard!</span>
    </div>
  </div>
</MainLayout>

<script>
  // Astro client-side script
  document.addEventListener('DOMContentLoaded', function() {
    const copyBtn = document.getElementById('copyEmailBtn');
    const toast = document.getElementById('copyToast');
    
    if (copyBtn) {
      copyBtn.addEventListener('click', function() {
        const email = 'parimalhodar.dev@gmail.com';
        
        // Modern clipboard API
        if (navigator.clipboard) {
          navigator.clipboard.writeText(email).then(() => {
            showToast();
          }).catch(() => {
            fallbackCopy(email);
          });
        } else {
          fallbackCopy(email);
        }
      });
    }
    
    function showToast() {
      if (toast) {
        toast.classList.remove('opacity-0', 'translate-y-2', 'pointer-events-none');
        toast.classList.add('opacity-100', 'translate-y-0');
        setTimeout(() => {
          toast.classList.add('opacity-0', 'translate-y-2', 'pointer-events-none');
          toast.classList.remove('opacity-100', 'translate-y-0');
        }, 3000);
      }
    }
    
    function fallbackCopy(text: string) {
      const textArea = document.createElement('textarea');
      textArea.value = text;
      document.body.appendChild(textArea);
      textArea.select();
      try {
        document.execCommand('copy');
        showToast();
      } catch (err) {
        console.error('Failed to copy email');
      }
      document.body.removeChild(textArea);
    }
  });
</script>

<style>
  /* Custom animations for Astro */
  @keyframes pulse {
    0%, 100% {
      opacity: 0.3;
    }
    50% {
      opacity: 0.5;
    }
  }
  
  .animate-pulse {
    animation: pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  
  .delay-1000 {
    animation-delay: 1s;
  }
  
  /* Gradient text support for older browsers */
  .bg-clip-text {
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>
