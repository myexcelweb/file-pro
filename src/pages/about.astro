---
// About Page - About Parimal Hodar | File Pro
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="About Parimal Hodar | File Pro"
  description="Learn more about Parimal Hodar and the File Pro suite of professional digital tools for PDF, Excel, AI image editing, and productivity."
  keywords="Parimal Hodar, About, digital tools, PDF editor, Excel tools, AI image editor, portfolio"
>
  <!-- Centered container for main content -->
  <div class="max-w-3xl mx-auto">
    <!-- Page Header -->
    <div class="text-center">
      <h1 class="text-4xl font-extrabold mb-4">
        About File Pro
        <span class="text-xl font-normal block mt-1">by Parimal Hodar</span>
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-300 mb-6">
        Welcome to File Pro! 🚀 This platform by Parimal Hodar serves as a central hub for a suite of powerful, professional-grade digital tools designed to streamline your workflow and boost your productivity.
      </p>
    </div>

    <!-- Detailed Content Sections -->
    <div class="mt-12 text-left space-y-8">
      <!-- Mission Section -->
      <div>
        <h2 class="text-2xl font-bold mb-3">Our Mission</h2>
        <p class="text-gray-700 dark:text-gray-300">
          Our mission is to empower professionals by providing intelligent, secure, and user-friendly applications that solve complex digital challenges. From advanced PDF editing and AI-powered image manipulation to sophisticated Excel processing and data analytics, each tool in our suite is crafted with precision and performance in mind.
        </p>
      </div>

      <!-- Why Choose Us Section -->
      <div>
        <h2 class="text-2xl font-bold mb-3">Why Choose Our Tools?</h2>
        <ul class="list-disc list-inside space-y-2 text-gray-700 dark:text-gray-300">
          <li>
            <strong>AI-Powered Intelligence:</strong> Smarter, faster, and more accurate results across our applications.
          </li>
          <li>
            <strong>User-Centric Design:</strong> Intuitive and easy-to-use tools with professional functionality.
          </li>
          <li>
            <strong>Security & Reliability:</strong> Robust standards ensure your data is safe.
          </li>
          <li>
            <strong>Comprehensive Solutions:</strong> Wide-ranging professional tools accessible from one platform.
          </li>
        </ul>
      </div>
    </div>

    <!-- Call to Action Button -->
    <div class="text-center mt-12">
      <a
        href="/#tools"
        class="inline-block bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700 transition"
      >
        Explore Our Tools
      </a>
    </div>
  </div>
</MainLayout>
